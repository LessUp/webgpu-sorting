{
  "name": "webgpu-sorting",
  "version": "1.0.0",
  "description": "High-performance GPU sorting algorithms using WebGPU compute shaders",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/shaders"
  ],
  "keywords": [
    "webgpu",
    "gpu",
    "sorting",
    "bitonic-sort",
    "radix-sort",
    "compute-shader",
    "wgsl",
    "parallel-computing"
  ],
  "author": "WebGPU Sorting Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LessUp/webgpu-sorting.git"
  },
  "bugs": {
    "url": "https://github.com/LessUp/webgpu-sorting/issues"
  },
  "homepage": "https://github.com/LessUp/webgpu-sorting#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "tsc && vite build --mode analyze",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "docs:generate": "typedoc --options typedoc.json",
    "docs:serve": "npx serve docs/api",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.2.2",
    "@webgpu/types": "^0.1.40",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^3.15.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.2"
  }
}
